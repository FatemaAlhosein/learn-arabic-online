.env
.env.*
!.env.example

# --- IDE / editors ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- OS clutter ---
.DS_Store
Thumbs.db

# --- Coverage / testing ---
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/

# --- Build / dist ---
build/
dist/
